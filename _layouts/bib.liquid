<div class="row mb-3 align-items-start">
  {% if site.enable_publication_thumbnails %}
    <div class="col col-sm-2 abbr">
      {% if entry.abbr %}
        {% if site.data.venues[entry.abbr] %}
          {% assign venue_style = site.data.venues[entry.abbr].color | prepend: 'style="background-color:' | append: '"' %}
          <abbr class="badge rounded w-100" {% if venue_style %}{{ venue_style }}{% endif %}>
            {% if site.data.venues[entry.abbr].url %}
              <a href="{{ site.data.venues[entry.abbr].url }}">{{ entry.abbr }}</a>
            {% else %}
              {{ entry.abbr }}
            {% endif %}
          </abbr>
        {% else %}
          <abbr class="badge rounded w-100">{{ entry.abbr }}</abbr>
        {% endif %}
      {% endif %}

      {% if entry.preview %}
        {% assign entry_path = entry.preview | prepend: '/assets/img/publication_preview/' %}
        {% include figure.liquid
            loading="eager"
            path=entry_path
            sizes="200px"
            class="preview z-depth-1 rounded mt-1"
            zoomable=true
            avoid_scaling=true
            alt=entry.preview %}
      {% endif %}
    </div>
  {% endif %}

  <div id="{{ entry.key }}" class="{% if site.enable_publication_thumbnails %}col-sm-10{% else %}col-sm-12{% endif %}">

    <!-- Title -->
    <div class="title fw-bold">{{ entry.title }}</div>

    <!-- Authors -->
    <div class="author mb-1">
      {% assign author_array_size = entry.author_array | size %}
      {% assign author_array_limit = site.max_author_limit | default: author_array_size %}

      {% for author in entry.author_array limit: author_array_limit %}
        {% assign author_last_html = author.last | regex_replace: '([*∗†‡§¶‖&^]+)', '<sup>\1</sup>' %}
        {% if site.scholar.last_name contains author.last and site.scholar.first_name contains author.first %}
          <em>{{ author.first }} {{ author_last_html }}</em>
        {% else %}
          {{ author.first }} {{ author_last_html }}
        {% endif %}
        {% if forloop.last == false %}
          {% if forloop.length > 2 %}, {% elsif forloop.length == 2 %} {% endif %}
        {% endif %}
      {% endfor %}

      {% assign more_authors = author_array_size | minus: author_array_limit %}
      {% if more_authors > 0 %}
        , and
        <span class="more-authors text-primary" style="cursor:pointer;"
          title="{{ more_authors }} more authors"
          onclick="
            var element = this;
            element.setAttribute('title','');
            var more_authors_text = '';
            {% for author in entry.author_array offset: author_array_limit %}
              more_authors_text += '{{ author.first }} {{ author.last }}{% unless forloop.last %}, {% endunless %}';
            {% endfor %}
            element.innerHTML = more_authors_text;
          ">
          {{ more_authors }} more authors
        </span>
      {% endif %}
    </div>

    <!-- Journal / Conference / Book info -->
    {% assign proceedings = 'inproceedings,incollection' | split: ',' %}
    {% assign thesis = 'thesis,mastersthesis,phdthesis' | split: ',' %}

    {% if entry.type == 'article' %}
      {% capture entrytype %}<em>{{ entry.journal }}</em>{% endcapture %}
    {% elsif proceedings contains entry.type %}
      {% capture entrytype %}<em>In {{ entry.booktitle }}</em>{% endcapture %}
    {% elsif thesis contains entry.type %}
      {% capture entrytype %}<em>{{ entry.school }}</em>{% endcapture %}
    {% else %}
      {% capture entrytype %}{% endcapture %}
    {% endif %}

    {% capture periodical %}
      {{ entrytype }}
      {% if entry.volume %}, Vol. {{ entry.volume }}{% endif %}
      {% if entry.number %}({{ entry.number }}){% endif %}
      {% if entry.pages %}, pp. {{ entry.pages }}{% endif %}
      {% if entry.year %}, {{ entry.year }}{% endif %}
    {% endcapture %}
    <div class="periodical mb-1">{{ periodical }}</div>

    <!-- Buttons: Abstract, DOI, arXiv, InspireHEP -->
    <div class="links mb-2">
      {% if entry.abstract %}
        <a class="abstract btn btn-sm btn-outline-primary me-1"
           role="button"
           data-bs-toggle="popover"
           data-bs-html="true"
           data-bs-trigger="click"
           data-bs-content="{{ entry.abstract | escape | strip_newlines }}">
           Abstract
        </a>
      {% endif %}

      {% if entry.doi %}
        <a href="https://doi.org/{{ entry.doi }}" class="btn btn-sm btn-outline-secondary me-1" target="_blank">DOI</a>
      {% endif %}

      {% if entry.arxiv %}
        <a href="https://arxiv.org/abs/{{ entry.arxiv }}" class="btn btn-sm btn-outline-secondary me-1" target="_blank">arXiv</a>
      {% elsif entry.eprint %}
        <a href="https://arxiv.org/abs/{{ entry.eprint }}" class="btn btn-sm btn-outline-secondary me-1" target="_blank">arXiv</a>
      {% endif %}

      {% if site.enable_publication_badges.inspirehep and entry.inspirehep_id %}
        <a href="https://inspirehep.net/literature/{{ entry.inspirehep_id }}" target="_blank">
          <img src="https://img.shields.io/badge/inspire-{% inspirehep_citations entry.inspirehep_id %}-001628?logo=inspire&logoColor=001628&labelColor=beige"
               alt="{% inspirehep_citations entry.inspirehep_id %} InspireHEP citations">
        </a>
      {% endif %}
    </div>
  </div>
</div>
