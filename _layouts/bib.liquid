{% assign author_array_limit = 5 %}  {# show first 5 authors #}

<div class="publication-list">
  {% assign last_year = '' %}
  {% for entry in site.bibliography %}
    {% if entry.year != last_year %}
      <div class="publication-year font-weight-bold mb-2">{{ entry.year }}</div>
      {% assign last_year = entry.year %}
    {% endif %}

    <div class="publication-item row mb-3 align-items-start">
      <div class="col-md-2 text-md-right text-sm-left year">
        {% if entry.year != last_year %}
          {{ entry.year }}
        {% endif %}
      </div>
      <div class="col-md-10">
        <div class="authors mb-1">
          {% assign more_authors = entry.author_array.size | minus: author_array_limit %}
          {% for author in entry.author_array limit: author_array_limit %}
            {{ author.first }} {{ author.last }}{% unless forloop.last %}, {% endunless %}
          {% endfor %}
          {% if more_authors > 0 %}
            <span class="more-authors text-primary" style="cursor:pointer;"
                  data-more-authors="{% for author in entry.author_array offset: author_array_limit %}{{ author.first }} {{ author.last }}{% unless forloop.last %}, {% endunless %}{% endfor %}">
              +{{ more_authors }} more
            </span>
          {% endif %}
        </div>

        <div class="title mb-1">
          <strong>{{ entry.title }}</strong>
        </div>

        <div class="journal text-muted mb-1">
          {% if entry.journal %}{{ entry.journal }}{% endif %}
          {% if entry.volume %} {{ entry.volume }}{% endif %}
          {% if entry.pages %}:{{ entry.pages }}{% endif %}
        </div>

        <div class="publication-buttons mb-2">
          {% if entry.doi %}
            <a class="btn btn-sm btn-outline-primary" target="_blank" href="https://doi.org/{{ entry.doi }}">DOI</a>
          {% endif %}
          {% if entry.arxiv %}
            <a class="btn btn-sm btn-outline-info" target="_blank" href="https://arxiv.org/abs/{{ entry.arxiv }}">arXiv</a>
          {% endif %}
          {% if entry.inspirehep %}
            <a class="btn btn-sm btn-outline-secondary" target="_blank" href="{{ entry.inspirehep }}">InspireHEP</a>
          {% endif %}
        </div>
      </div>
    </div>
  {% endfor %}
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
  document.querySelectorAll('.more-authors').forEach(function(element) {
    element.addEventListener('click', function() {
      var authorsText = element.getAttribute('data-more-authors');
      if(authorsText) {
        element.textContent = authorsText;
      }
    });
  });
});
</script>

<style>
.publication-year {
  font-size: 1.25rem;
}

.publication-item .year {
  min-width: 80px;
}

.publication-buttons a {
  margin-right: 0.5rem;
  margin-bottom: 0.25rem;
}

.more-authors {
  text-decoration: underline;
  cursor: pointer;
}
</style>
