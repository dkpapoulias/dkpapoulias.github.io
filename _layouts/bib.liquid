---
# _layouts/bib.liquid
---

<div class="row">
  {% if site.enable_publication_thumbnails %}
    <div class="col col-sm-2 abbr">
      {%- if entry.abbr -%}
        {%- if site.data.venues[entry.abbr] -%}
          {% assign venue_style = null %}
          {% if site.data.venues[entry.abbr].color != blank %}
            {% assign venue_style = site.data.venues[entry.abbr].color | prepend: 'style="background-color:' | append: '"' %}
          {%- endif -%}
          <abbr class="badge rounded w-100" {% if venue_style %}{{ venue_style }}{% endif %}>
            {% if site.data.venues[entry.abbr].url %}
              <a href="{{ site.data.venues[entry.abbr].url }}">{{ entry.abbr }}</a>
            {% else %}
              <div>{{- entry.abbr -}}</div>
            {% endif %}
          </abbr>
        {% else %}
          <abbr class="badge rounded w-100">{{ entry.abbr }}</abbr>
        {% endif %}
      {% endif %}

      {% if entry.preview %}
        {% assign entry_path = entry.preview %}
        {% unless entry.preview contains '://' %}
          {% assign entry_path = '/assets/img/publication_preview/' | append: entry.preview %}
        {% endunless %}
        <img class="preview z-depth-1 rounded" src="{{ entry_path }}">
      {% endif %}
    </div>
  {% endif %}

  <div id="{{ entry.key }}" class="{% if site.enable_publication_thumbnails %}col-sm-8{% else %}col-sm-10{% endif %}">
    <!-- Title -->
    <div class="title">{{ entry.title }}</div>

    <!-- Authors -->
    <div class="author">
      {% assign author_array_size = entry.author_array | size %}
      {% assign author_array_limit = site.max_author_limit | default: author_array_size %}
      {% if author_array_size < author_array_limit %}
        {% assign author_array_limit = author_array_size %}
      {% endif %}

      {%- for author in entry.author_array limit: author_array_limit -%}
        {% assign author_is_self = false %}
        {% assign author_last_name = author.last | regex_replace: '[*∗†‡§¶‖&^]', '' %}
        {% assign author_last_html = author.last | regex_replace: '([*∗†‡§¶‖&^]+)', '<sup>\1</sup>' %}
        {% if site.scholar.last_name contains author_last_name and site.scholar.first_name contains author.first %}
          {% assign author_is_self = true %}
        {% endif %}
        {% assign coauthor_url = null %}
        {% assign clean_last_name = author_last_name | downcase | remove_accents %}
        {% if site.data.coauthors[clean_last_name] %}
          {% for coauthor in site.data.coauthors[clean_last_name] %}
            {% if coauthor.firstname contains author.first %}
              {% assign coauthor_url = coauthor.url %}
              {% break %}
            {% endif %}
          {% endfor %}
        {% endif %}

        {%- if forloop.index0 > 0 %}
          {% if forloop.index0 < author_array_limit - 1 %}, {% elsif forloop.index0 == author_array_limit -1 and author_array_size <= author_array_limit %} and {% endif %}
        {% endif %}

        {%- if author_is_self -%}
          <em>{{ author.first }} {{ author_last_html }}</em>
        {%- else -%}
          {% if coauthor_url %}
            <a href="{{ coauthor_url }}">{{ author.first }} {{ author_last_html }}</a>
          {% else %}
            {{ author.first }} {{ author_last_html }}
          {% endif %}
        {% endif %}
      {% endfor %}

      {% assign more_authors = author_array_size | minus: author_array_limit %}
      {% if more_authors > 0 %}
        , and
        <span class="more-authors" title="click to view {{ more_authors }} more author{% if more_authors > 1 %}s{% endif %}" 
              onclick="var e=$(this);var t=e.text()==='{{ more_authors }} more author{% if more_authors > 1 %}s{% endif %}' ? '{{ entry.author_array | slice: author_array_limit, more_authors | map:'first' | join:' ' }}' : '{{ more_authors }} more author{% if more_authors > 1 %}s{% endif %}';e.text(t);">
          {{ more_authors }} more author{% if more_authors > 1 %}s{% endif %}
        </span>
      {% endif %}
    </div>

    <!-- Journal/Proceedings/Thesis -->
    {% capture parts %}
      {% if entry.type == 'article' %}
        {% if entry.journal %}<em>{{ entry.journal }}</em>{% endif %}
        {% if entry.volume %}vol. {{ entry.volume }}{% endif %}
        {% if entry.number %}no. {{ entry.number }}{% endif %}
        {% if entry.pages %}pp. {{ entry.pages }}{% endif %}
      {% elsif entry.type == 'inproceedings' or entry.type == 'incollection' %}
        {% if entry.booktitle %}<em>In {{ entry.booktitle }}</em>{% endif %}
        {% if entry.pages %}pp. {{ entry.pages }}{% endif %}
      {% elsif entry.type contains 'thesis' %}
        {% if entry.school %}<em>{{ entry.school }}</em>{% endif %}
      {% endif %}
      {% if entry.year %}{{ entry.year }}{% endif %}
    {% endcapture %}

    {% assign parts_array = parts | split: ',' | map: 'strip' | reject: '' %}
    {% capture entrytype %}{{ parts_array | join: ', ' }}{% endcapture %}

    <div class="periodical">{{ entrytype }}</div>
    {% if entry.note %}<div class="periodical">{{ entry.note }}</div>{% endif %}

    <!-- Links -->
    <div class="links">
      {% if entry.doi %}<a href="https://doi.org/{{ entry.doi }}" class="btn btn-sm z-depth-0">DOI</a>{% endif %}
      {% if entry.arxiv %}<a href="http://arxiv.org/abs/{{ entry.arxiv }}" class="btn btn-sm z-depth-0">arXiv</a>{% endif %}
      {% if entry.pdf %}
        {% assign pdf_link = entry.pdf %}
        {% unless pdf_link contains '://' %}{% assign pdf_link = '/assets/pdf/' | append: entry.pdf %}{% endunless %}
        <a href="{{ pdf_link }}" class="btn btn-sm z-depth-0">PDF</a>
      {% endif %}
    </div>

    <!-- Publication Badges -->
    {% if site.enable_publication_badges %}
      <div class="badges">
        {% if site.enable_publication_badges.inspirehep and entry.inspirehep_id %}
          <a href="https://inspirehep.net/literature/{{ entry.inspirehep_id }}" aria-label="InspireHEP" role="button">
            <img src="https://img.shields.io/badge/inspire-{% inspirehep_citations entry.inspirehep_id %}-001628?logo=inspire&logoColor=001628&labelColor=beige" alt="InspireHEP citations">
          </a>
        {% endif %}
      </div>
    {% endif %}

    <!-- Hidden blocks -->
    {% if entry.abstract %}<div class="abstract hidden"><p>{{ entry.abstract }}</p></div>{% endif %}
    {% if entry.bibtex_show %}<div class="bibtex hidden"><pre>{{ entry.bibtex }}</pre></div>{% endif %}
  </div>
</div>
