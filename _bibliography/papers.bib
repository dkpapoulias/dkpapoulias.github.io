@article{Papoulias:2017qdn,
  author       = "Papoulias, D. K. and Kosmas, T. S.",
  title        = "{COHERENT constraints to conventional and exotic neutrino physics}",
  eprint       = "1711.09773",
  archivePrefix= "arXiv",
  primaryClass = "hep-ph",
  doi          = "10.1103/PhysRevD.97.033003",
  journal      = "Phys. Rev. D",
  volume       = "97",
  number       = "3",
  pages        = "033003",
  year         = "2018",
  inspirehep_id = {1639033},
  abstract     = {The process of neutral-current coherent elastic neutrino-nucleus scattering has been recently measured by the COHERENT experiment. On the basis of the observed signal and nuclear calculations for the relevant Cs and I isotopes, constraints on both conventional and exotic neutrino physics are updated. The study concentrates on SM extensions involving vector and tensor nonstandard interactions, neutrino electromagnetic properties, light sterile neutrino states, and scenarios with new propagator fields such as vector Z' and scalar bosons.}
}

@article{Miranda:2020tif,
  author       = "Miranda, O. G. and Papoulias, D. K. and Sanchez Garcia, G. and Sanders, O. and T{\'o}rtola, M. and Valle, J. W. F.",
  title        = "{Implications of the first detection of coherent elastic neutrino-nucleus scattering (CEvNS) with Liquid Argon}",
  eprint       = "2003.12050",
  archivePrefix= "arXiv",
  primaryClass = "hep-ph",
  doi          = "10.1007/JHEP05(2020)130",
  journal      = "JHEP",
  volume       = "05",
  pages        = "130",
  year         = "2020",
  inspirehep_id = {1788440},
  abstract     = {The CENNS-10 experiment of the COHERENT collaboration has reported the first detection of coherent-elastic neutrino-nucleus scattering in liquid Argon with more than $3\sigma$ significance. Exploiting the new data to probe parameters of key importance to CEvNS within and beyond the Standard Model, we derive a first measurement of the neutron rms charge radius of Argon and an improved determination of the weak mixing angle in the low energy regime. Constraints on neutrino non-standard interactions, electromagnetic properties, and light mediators are also updated.}
}

@article{DeRomeri:2022twg,
  author       = "De Romeri, V. and Miranda, O. G. and Papoulias, D. K. and Sanchez Garcia, G. and T{\'o}rtola, M. and Valle, J. W. F.",
  title        = "{Physics implications of a combined analysis of COHERENT CsI and LAr data}",
  eprint       = "2211.11905",
  archivePrefix= "arXiv",
  primaryClass = "hep-ph",
  doi          = "10.1007/JHEP04(2023)035",
  journal      = "JHEP",
  volume       = "04",
  pages        = "035",
  year         = "2023",
  inspirehep_id = {2513697},
  abstract     = {The observation of coherent elastic neutrino nucleus scattering has opened the window to many physics opportunities. We perform a detailed statistical analysis of the full COHERENT CsI data and combine it with the previous argon result, discussing implications from tests of the Standard Model to new physics probes. In particular, we update previous measurements of the weak mixing angle and the neutron root mean square charge radius for CsI and argon, taking into account experimental uncertainties associated to efficiency and timing distribution of neutrino fluxes.}
}

@article{Papoulias:2019txv,
  author       = "Papoulias, Dimitrios K.",
  title        = "{COHERENT constraints after the COHERENT-2020 quenching factor measurement}",
  eprint       = "1907.11644",
  archivePrefix= "arXiv",
  primaryClass = "hep-ph",
  doi          = "10.1103/PhysRevD.102.113004",
  journal      = "Phys. Rev. D",
  volume       = "102",
  number       = "11",
  pages        = "113004",
  year         = "2020",
  inspirehep_id = {1746478},
  abstract     = {An improved quenching factor (QF) measurement for low-energy nuclear recoils in CsI[Na] has been reported by the COHERENT Collaboration. The new energy-dependent QF is characterized by reduced systematic uncertainty and leads to better agreement between the experimental COHERENT data and the Standard Model expectation. Updated constraints on parameters describing coherent elastic neutrino-nucleus scattering within and beyond the SM are reported, along with a discussion of how the new QF affects their interpretation.}
}

@article{AristizabalSierra:2020rom,
  author       = "Aristizabal Sierra, D. and De Romeri, V. and Flores, L. J. and Papoulias, D. K.",
  title        = "{Axionlike particles searches in reactor experiments}",
  eprint       = "2010.15712",
  archivePrefix= "arXiv",
  primaryClass = "hep-ph",
  doi          = "10.1007/JHEP03(2021)294",
  journal      = "JHEP",
  volume       = "03",
  pages        = "294",
  year         = "2021",
  inspirehep_id = {1826785},
  abstract     = {Reactor neutrino experiments provide a rich environment for the study of axionlike particles (ALPs). Using the intense photon flux produced in the nuclear reactor core, these experiments have the potential to probe ALPs with masses below 10 MeV. The feasibility of searches via ALPs produced through Primakoff and Compton-like processes as well as nuclear transitions is explored, demonstrating that reactor-based experiments have high potential to test ALP-photon couplings and masses currently probed only by cosmological and astrophysical observations.}
}

@article{A:2022acy,
    author = "A., ShivaSankar K. and Majumdar, Anirban and Papoulias, Dimitrios K. and Prajapati, Hemant and Srivastava, Rahul",
    title = "{Implications of first LZ and XENONnT results: A comparative study of neutrino properties and light mediators}",
    eprint = "2208.06415",
    archivePrefix = "arXiv",
    primaryClass = "hep-ph",
    doi = "10.1016/j.physletb.2023.137742",
    journal = "Phys. Lett. B",
    volume = "839",
    pages = "137742",
    year = "2023",
  inspirehep_id = {2135958},
  abstract     = {Next generation direct dark matter detection experiments are favorable facilities to probe neutrino properties and light mediators beyond the Standard Model. We explore the implications of the recent data reported by LUX-ZEPLIN (LZ) and XENONnT collaborations on electromagnetic neutrino interactions and neutrino generalized interactions (NGIs). We show that XENONnT places the most stringent upper limits on the effective and transition neutrino magnetic moment (of the order of few $\times 10^{-12}\mu_B$) as well as stringent constraints to neutrino millicharge (of the order of ∼$10^{-13}e$)–competitive to LZ–and improved by about one order of magnitude in comparison to existing constraints coming from Borexino and TEXONO. We furthermore explore the XENONnT and LZ sensitivities to simplified models with light NGIs and find improved constraints in comparison to those extracted from Borexino-Phase II data.}
}

@article{Melas:2023olz,
    author = "Melas, Pantelis and Papoulias, Dimitrios K. and Saoulidou, Niki",
    title = "{Probing generalized neutrino interactions with the DUNE Near Detector}",
    eprint = "2303.07094",
    archivePrefix = "arXiv",
    primaryClass = "hep-ph",
    doi = "10.1007/JHEP07(2023)190",
    journal = "JHEP",
    volume = "07",
    pages = "190",
    year = "2023",
  inspirehep_id = {2641530},
  abstract     = {We explore the prospects of constraining general non standard interactions involving light mediators through elastic neutrino-electron scattering events at the DUNE Near Detector (ND). We furthermore consider the special cases of light vector mediators in motivated models such as U(1)B−L, U(1)Lμ−Lτ,E6 and left-right symmetry. The present analysis is based on detailed Monte Carlo simulations of the expected DUNE-ND signal taking into account detector resolution effects, realistic backgrounds as well as On-Axis and Off-Axis neutrino spectra. We show that the high intensity neutrino beam available at Fermilab can place competitive constraints surpassing those of low-energy neutrino searches and direct detection dark matter experiments.}
}

@article{Hellgren:2025gvf,
    author = "Hellgren, Matti and Papoulias, Dimitrios K. and Suhonen, Jouni",
    title = "{Inelastic neutrino-nucleus scattering off 203/205Tl in terms of the nuclear recoil energy using a hybrid nuclear model}",
    eprint = "2502.07909",
    archivePrefix = "arXiv",
    primaryClass = "nucl-th",
    doi = "10.1016/j.physletb.2025.139624",
    journal = "Phys. Lett. B",
    volume = "868",
    pages = "139624",
    year = "2025",
  inspirehep_id = {2879234},
  abstract     = {Nuclear structure calculations in the context of a novel hybrid nuclear model, combining the nuclear shell model and the microscopic quasiparticle-phonon model are presented. The predictivity of the hybrid model is tested by computing inelastic neutral-current neutrino-nucleus scattering cross sections off the stable thallium isotopes. The cross sections are presented in terms of the incoming neutrino energy, taking also into account the effect of nuclear recoil energy. Also reported are the expected event rates assuming neutrinos emerging from pion-decay at rest and the diffuse supernova neutrino background. Regarding solar neutrino rates, new results are presented in the context of the hybrid model and compared with previously reported results based solely on nuclear shell model calculations, demonstrating the improved accuracy of the adopted hybrid model at higher neutrino energies.}
}
