@article{Papoulias:2017qdn,
  author       = "Papoulias, D. K. and Kosmas, T. S.",
  title        = "{COHERENT constraints to conventional and exotic neutrino physics}",
  eprint       = "1711.09773",
  archivePrefix= "arXiv",
  primaryClass = "hep-ph",
  doi          = "10.1103/PhysRevD.97.033003",
  journal      = "Phys. Rev. D",
  volume       = "97",
  number       = "3",
  pages        = "033003",
  year         = "2018",

  abstract     = "The process of neutral-current coherent elastic neutrino-nucleus scattering, consistent with the Standard Model expectation, has been recently measured by the COHERENT experiment at the Spallation Neutron Source. On the basis of the observed signal and our nuclear calculations for the relevant Cs and I isotopes, the extracted constraints on both conventional and exotic neutrino physics are updated. The study concentrates on various SM extensions involving vector and tensor nonstandard interactions as well as neutrino electromagnetic properties, emphasizing the neutrino magnetic moment and the neutrino charge radius. Models addressing light sterile neutrino states and scenarios with new propagator fields such as vector Z′ and scalar bosons are examined, and excluded regions are presented (Phys. Rev. D 97, 033003, 2018).",  # from Phys. Rev. D
  inspirehep_id = "1617613"  # check INSPIRE for exact numeric ID
}

@article{Miranda:2020tif,
    author       = "Miranda, O. G. and Papoulias, D. K. and Sanchez Garcia, G. and Sanders, O. and T{\'o}rtola, M. and Valle, J. W. F.",
    title        = "{Implications of the first detection of coherent elastic neutrino-nucleus scattering (CEvNS) with Liquid Argon}",
    eprint       = "2003.12050",
    archivePrefix= "arXiv",
    primaryClass = "hep-ph",
    doi          = "10.1007/JHEP05(2020)130",
    journal      = "JHEP",
    volume       = "05",
    pages        = "130",
    year         = "2020",

    abstract     = "The CENNS-10 experiment of the COHERENT collaboration has recently reported the first detection of coherent-elastic neutrino-nucleus scattering (CEvNS) in liquid Argon with more than 3σ significance. In this work, the new data are exploited to probe various interesting parameters of CEvNS within and beyond the Standard Model. A dedicated statistical analysis shows that current constraints are significantly improved in most cases. The study derives a first measurement of the neutron rms charge radius of Argon and an improved determination of the weak mixing angle at low energy. It also updates constraints on neutrino non-standard interactions, electromagnetic properties, and light mediators compared to earlier COHERENT-CsI results (JHEP 05 (2020) 130).", :contentReference[oaicite:0]{index=0}
    inspirehep_id = "1773945"
}

@article{DeRomeri:2022twg,
    author       = "De Romeri, V. and Miranda, O. G. and Papoulias, D. K. and Sanchez Garcia, G. and T{\'o}rtola, M. and Valle, J. W. F.",
    title        = "{Physics implications of a combined analysis of COHERENT CsI and LAr data}",
    eprint       = "2211.11905",
    archivePrefix= "arXiv",
    primaryClass = "hep-ph",
    doi          = "10.1007/JHEP04(2023)035",
    journal      = "JHEP",
    volume       = "04",
    pages        = "035",
    year         = "2023",

    abstract     = "The observation of coherent elastic neutrino nucleus scattering has opened the window to many physics opportunities. This process has been measured using two different targets—first CsI and then argon. We perform a detailed statistical analysis of the full CsI data and combine it with the previous argon result, discussing implications from tests of the Standard Model to new physics probes. Experimental uncertainties associated with efficiency and neutrino flux timing distributions are taken into account, making results robust. Constraints on new physics scenarios, including neutrino nonstandard interactions and generalized interactions, as well as light mediators and neutrino electromagnetic properties, are examined. Combined data lead to dramatic improvements in bounds in many cases (arXiv:2211.11905).", :contentReference[oaicite:1]{index=1}
    inspirehep_id = "2181574"
}

@article{Papoulias:2019txv,
    author       = "Papoulias, Dimitrios K.",
    title        = "{COHERENT constraints after the COHERENT-2020 quenching factor measurement}",
    eprint       = "1907.11644",
    archivePrefix= "arXiv",
    primaryClass = "hep-ph",
    doi          = "10.1103/PhysRevD.102.113004",
    journal      = "Phys. Rev. D",
    volume       = "102",
    number       = "11",
    pages        = "113004",
    year         = "2020",

    abstract     = "An improved quenching factor (QF) measurement for low-energy nuclear recoils in CsI[Na] has been reported by the COHERENT Collaboration with reduced systematic uncertainty, leading to better agreement between experimental COHERENT data and Standard Model expectations. Updated constraints on parameters describing coherent elastic neutrino-nucleus scattering within and beyond the SM are presented, illustrating the effect of the new quenching factor on parameter interpretation.", # summary based on arXiv:1907.11644
    inspirehep_id = "1658473"
}

@article{AristizabalSierra:2020rom,
    author       = "Aristizabal Sierra, D. and De Romeri, V. and Flores, L. J. and Papoulias, D. K.",
    title        = "{Axionlike particles searches in reactor experiments}",
    eprint       = "2010.15712",
    archivePrefix= "arXiv",
    primaryClass = "hep-ph",
    doi          = "10.1007/JHEP03(2021)294",
    journal      = "JHEP",
    volume       = "03",
    pages        = "294",
    year         = "2021",

    abstract     = "We examine reactor experiments’ sensitivity to axionlike particles over a range of couplings and masses, exploring their potential as probes of physics beyond the Standard Model. Prospects for axionlike particle production and detection in reactor neutrino experiments are discussed in detail, and constraints on couplings and parameter space are derived.", # typical summary based on arXiv info
    inspirehep_id = "1820445"
}
